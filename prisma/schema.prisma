generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("engineer")
  avatarUrl String?
  createdAt DateTime @default(now())

  assignedReports Report[]  @relation("AssignedReports")
  tasks           Task[]
  expenses        Expense[]
}

model Expense {
  id          String   @id @default(uuid())
  title       String
  vendor      String?
  category    String   @default("software")
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  expenseDate DateTime
  paymentType String?
  paymentStatus String @default("paid")
  writeOffType String  @default("business")
  referenceUrl String?
  notes       String?
  taxYear     Int
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Restrict)
  receipts  ExpenseReceipt[]
}

model ExpenseReceipt {
  id        String   @id @default(uuid())
  expenseId String
  filename  String
  mimetype  String
  size      Int
  path      String
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

model Report {
  id               String      @id @default(uuid())
  type             ReportType
  priority         Priority    @default(medium)
  bugLevel         BugLevel?
  title            String
  description      String
  status           Status      @default(queued)
  queued           Boolean     @default(true)
  upvotes          Int         @default(0)
  tags             String[]
  devNotes         String?
  notifyOwner      Boolean  @default(false)
  publishStatus    String        @default("unpublished")
  discordUser      String
  discordUserId    String?
  discordChannel   String
  discordThreadId  String?
  discordMessageId String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  assignees        User[]      @relation("AssignedReports")
  attachments      Attachment[]
  messages         Message[]
  history          ReportHistory[]
}

model Attachment {
  id         String   @id @default(uuid())
  reportId   String
  type       String
  url        String
  discordUrl String?
  filename   String
  createdAt  DateTime @default(now())

  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Task {
  id        String   @id @default(uuid())
  text      String
  done      Boolean  @default(false)
  tag       String   @default("feature")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReportHistory {
  id         String   @id @default(uuid())
  reportId   String
  action     String
  detail     String?
  actorName  String
  actorId    String
  createdAt  DateTime @default(now())

  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Message {
  id            String   @id @default(uuid())
  reportId      String
  content       String
  authorName    String
  authorId      String
  authorAvatar  String?
  attachments   String[] 
  isBot         Boolean  @default(false)
  createdAt     DateTime @default(now())

  report        Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

enum ReportType {
  bug
  crash
  suggestion
}

enum Priority {
  low
  medium
  high
  critical
}

enum BugLevel {
  minor
  moderate
  major
}

enum Status {
  queued
  open
  in_progress
  reviewing
  resolved
  declined
}
